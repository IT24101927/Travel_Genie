# Copy this file to .env and fill in your values.
# IMPORTANT: Aiml code reads DATABASE_URL (single connection string), not DB_HOST/DB_USER vars.

# Database connection string used by Aiml modules.
# Local PostgreSQL example:
# DATABASE_URL=postgresql://postgres:yourpassword@localhost:5432/travelgenie
#
# Cloud/Neon example:
# DATABASE_URL=postgresql://username:password@host.region.aws.neon.tech/database?sslmode=verify-full
DATABASE_URL=postgresql://<user>:<password>@<host>:5432/<dbname>

# Port the Flask AI server listens on (default 5001)
AI_PORT=5001

# Set to "true" to enable Flask debug mode (development only)
FLASK_DEBUG=false

# Optional: place-weather cache TTL in seconds (default 900)
PLACE_WEATHER_CACHE_TTL_SECONDS=900

# Optional: weather API request timeout in seconds (default 6)
PLACE_WEATHER_TIMEOUT_SECONDS=6

# Railway provides PORT automatically at runtime.
# Keep AI_PORT for local runs only.
