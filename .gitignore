# TravelGenie - Dependencies and Build Artifacts

# Node modules
node_modules/
*/node_modules/

# Environment files
.env
.env.local
.env.*.local
Backend/.env
Frontend/.env

# Logs
logs/
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
lerna-debug.log*

# Build outputs
dist/
dist-ssr/
build/
.next/
out/
.nuxt/

# Cache directories
.cache/
.parcel-cache/
.vite/
.turbo/
.eslintcache
.npm
.yarn

# OS files
.DS_Store
Thumbs.db
*.swp
*.swo
*~

# IDE files
.vscode/
.idea/
*.suo
*.ntvs*
*.njsproj
*.sln
*.sw?

# Test coverage
coverage/
.nyc_output/

# Uploads (user content - ignore files but keep folder structure via .gitkeep)
Backend/uploads/*
!Backend/uploads/.gitkeep
!Backend/uploads/places
Backend/uploads/places/*
!Backend/uploads/places/.gitkeep
Backend/public/uploads/*
!Backend/public/uploads/.gitkeep

# Runtime data
pids
*.pid
*.seed
*.pid.lock

# TypeScript
*.tsbuildinfo

# Optional
.node_repl_history
*.tgz
.yarn-integrity

# Database files (if any local DBs)
*.db
*.sqlite
*.sqlite3

# Temporary files
*.tmp
*.temp
*.bak
*.backup
