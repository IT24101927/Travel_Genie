# Server Configuration
PORT=5000
NODE_ENV=development

# Database Configuration (PostgreSQL)
# Local database example:
# DATABASE_URL=postgresql://username:password@localhost:5432/travelgenie

# Neon Database (Cloud PostgreSQL):
# Get your connection string from https://console.neon.tech
DATABASE_URL=postgresql://username:password@host.region.aws.neon.tech/database?sslmode=verify-full

# JWT Secret
# Generate a secure random string for production
JWT_SECRET=your_jwt_secret_key_here_change_in_production
JWT_EXPIRE=7d

# CORS
CORS_ORIGIN=http://localhost:5173
FRONTEND_URL=http://localhost:5173

# SMTP Configuration (for password reset emails)
# If NOT set, the reset code will print in the server terminal instead.
#
# Gmail example:
#   1. Enable 2-Step Verification on your Google account
#   2. Go to https://myaccount.google.com/apppasswords
#   3. Generate an App Password (16 chars) and use it as SMTP_PASS
#
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=your_email@gmail.com
SMTP_PASS=your_app_password_here
SMTP_FROM="TravelGenie" <your_email@gmail.com>

# AI service proxy target
# Prefer AI_BASE_URL in production (Railway/Render URL), e.g.:
# AI_BASE_URL=https://travelgenie-ai-production.up.railway.app
AI_BASE_URL=

# Fallback host/port (used when AI_BASE_URL is empty)
AI_HOST=localhost
AI_SERVICE_PORT=5001

# Optional timeout tuning for place AI proxy (milliseconds)
PLACE_AI_TIMEOUT_MS=20000

# Optional timeout tuning for hotel and budget AI proxy (milliseconds)
HOTEL_AI_TIMEOUT_MS=20000
BUDGET_AI_TIMEOUT_MS=60000
